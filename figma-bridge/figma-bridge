#!/usr/bin/env bash
# Figma Bridge Skill Wrapper Script
# This script wraps the Python figma_bridge module for OpenClaw execution

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON_SCRIPT="$SCRIPT_DIR/scripts/figma_bridge.py"

# Ensure Python script is executable
chmod +x "$PYTHON_SCRIPT" 2>/dev/null || true

# Run the Python script with all arguments
exec python3 "$PYTHON_SCRIPT" "$@"
