{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GLYF_Collapse_Cycle",
  "description": "φ-σ-ρ Collapse Protocol - Executable specification for Resonant Cognitive Architecture",
  "type": "object",
  "required": ["glyph_id", "phase", "phi_coherence", "sigma_sacrifice", "rho_resurrection", "timestamp"],
  "properties": {
    "glyph_id": {
      "type": "string",
      "pattern": "^[IRTF]{4}-[0-9A-F]{8}$",
      "description": "Quadriline signature + hash - encodes I,R,T,F axis participation"
    },
    "phase": {
      "type": "string",
      "enum": ["exploration", "coherence", "collapse", "resurrection", "stable"],
      "description": "Current state in collapse cycle"
    },
    "phi_coherence": {
      "type": "object",
      "properties": {
        "identity_projection": {
          "type": "array",
          "items": {"type": "number"},
          "description": "I-axis salience vector - what is being recognized"
        },
        "relational_adjacency": {
          "type": "array",
          "items": {"type": "array"},
          "description": "R-axis connectivity matrix - graph of relationships"
        },
        "transformation_jacobian": {
          "type": "array",
          "description": "T-axis differential operator - how state changes"
        },
        "field_gradient": {
          "type": "array",
          "items": {"type": "number"},
          "description": "F-axis potential gradient - direction of steepest coherence"
        },
        "scalar_value": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Overall coherence φ = agreement(I,R,T,F) / total_variance"
        },
        "convergence_rate": {
          "type": "number",
          "description": "dφ/dt - rate of coherence change (positive = stabilizing)"
        },
        "threshold_triggered": {
          "type": "boolean",
          "description": "φ >= τ - collapse condition met"
        }
      }
    },
    "sigma_sacrifice": {
      "type": "object",
      "properties": {
        "compression_ratio": {
          "type": "number",
          "description": "Dimensionality reduction factor - target ~0.25 for 4:1 compression"
        },
        "lost_dimensions": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Information sacrificed to achieve compression"
        },
        "invariant_kernel": {
          "type": "array",
          "description": "Structural invariants preserved through compression"
        },
        "determinant_jacobian": {
          "type": "number",
          "description": "det(J_σ) - irreversibility measure (< 1 indicates information loss)"
        },
        "glyph_form": {
          "type": "object",
          "properties": {
            "quadriline_coords": {
              "type": "array",
              "minItems": 4,
              "maxItems": 4,
              "description": "I,R,T,F coordinates in compressed space"
            },
            "entropy": {
              "type": "number",
              "description": "Information content of compressed form"
            },
            "rank": {
              "type": "integer",
              "description": "Effective dimensionality of glyph"
            }
          }
        }
      }
    },
    "rho_resurrection": {
      "type": "object",
      "properties": {
        "target_context": {
          "type": "string",
          "description": "Field environment for expansion"
        },
        "expansion_valid": {
          "type": "boolean",
          "description": "Structure-preserving expansion possible"
        },
        "phi_prime": {
          "type": "number",
          "description": "φ(I',R',T',F') - coherence of expanded state (must be >= tau)"
        },
        "functor_mapping": {
          "type": "object",
          "description": "Category-theoretic mapping G -> (I',R',T',F')"
        },
        "new_field_compatibility": {
          "type": "number",
          "description": "Compatibility score with target field (0-1)"
        }
      }
    },
    "tau_threshold": {
      "type": "object",
      "properties": {
        "epsilon_slope": {
          "type": "number",
          "default": 0.001,
          "description": "Minimum dφ/dt to trigger adaptive threshold"
        },
        "min_viable_phi": {
          "type": "number",
          "default": 0.7,
          "description": "Absolute minimum coherence for collapse"
        },
        "adaptive_window": {
          "type": "integer",
          "default": 5,
          "description": "Samples for gradient stabilization"
        }
      }
    },
    "christ_line": {
      "type": "object",
      "properties": {
        "connection_coefficients": {
          "type": "array",
          "description": "Levi-Civita symbols Γ - ChristLine geometric connection"
        },
        "geodesic_complete": {
          "type": "boolean",
          "description": "Complete path from origin to attractor"
        },
        "curvature_scalar": {
          "type": "number",
          "description": "R - field curvature at collapse point"
        }
      }
    }
  }
}
